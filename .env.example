# ─── FRONTEND (Vercel) ───────────────────────────────────────────────────────
# URL del backend PHP desplegado en Railway (sin slash final)
# La obtienes en Railway → tu servicio PHP → Settings → Networking → Public URL
PUBLIC_API_URL=https://TU-PROYECTO.up.railway.app

# ─── BACKEND (Railway) ───────────────────────────────────────────────────────
# Railway inyecta estas variables automáticamente al añadir el plugin MySQL:
# DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS (MYSQLPASSWORD, etc.)
# También puedes configurarlas manualmente en Railway → Variables

# URL del frontend en Vercel (para CORS en el backend)
# La obtienes en Vercel → tu proyecto → Settings → Domains
FRONTEND_URL=https://TU-PROYECTO.vercel.app

# URL exacta que se enviará por email para cambiar contraseña
# Usa tu dominio final o el dominio Vercel: https://TU-PROYECTO.vercel.app/reset-password
RESET_PASSWORD_URL=https://TU-PROYECTO.vercel.app/reset-password

# Clave privada estable para firmar tokens Bearer de autenticación
# Genera un valor largo y aleatorio en Railway → Variables
AUTH_SECRET=CAMBIA_ESTE_VALOR_LARGO_Y_SECRETO

# SMTP para recuperación de contraseña
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USER=no-reply@tudominio.com
SMTP_PASS=CAMBIA_ESTE_PASSWORD_SMTP
