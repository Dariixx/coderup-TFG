---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import BackToTop from "../components/react/BackToTop.tsx";
import ContactForm from "../components/react/ContactForm.tsx";
---

<BaseLayout title="Contacto | CoderUp">
  <Navbar />

  <section class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <span class="text-[#00FF66] text-sm font-semibold uppercase tracking-widest">Contacto</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mt-3 mb-4">¿Hablamos?</h1>
        <p class="text-[#888] text-lg max-w-2xl mx-auto">
          ¿Tienes dudas, sugerencias o quieres colaborar? Escríbenos y te respondemos lo antes posible.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">

        <!-- INFO DE CONTACTO -->
        <div class="space-y-8">
          <div class="bg-[#1A1A1A] border border-[#2A2A2A] rounded-2xl p-8 space-y-8">
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#00FF66]/10 rounded-xl flex items-center justify-center shrink-0">
                <Icon name="lucide:mail" class="w-6 h-6 text-[#00FF66]" />
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Email</h3>
                <p class="text-[#888] text-sm">Respuesta en menos de 24h</p>
                <a href="mailto:hola@coderup.dev" class="text-[#00FF66] text-sm hover:underline">hola@coderup.dev</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#00FF66]/10 rounded-xl flex items-center justify-center shrink-0">
                <Icon name="lucide:message-circle" class="w-6 h-6 text-[#00FF66]" />
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Chat en vivo</h3>
                <p class="text-[#888] text-sm">Lunes a Viernes, 9:00 - 18:00</p>
                <p class="text-[#00FF66] text-sm">Disponible en la plataforma</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#00FF66]/10 rounded-xl flex items-center justify-center shrink-0">
                <Icon name="lucide:map-pin" class="w-6 h-6 text-[#00FF66]" />
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Ubicación</h3>
                <p class="text-[#888] text-sm">100% remoto desde España</p>
                <p class="text-[#888] text-sm">Trabajamos con todo el mundo</p>
              </div>
            </div>

          </div>

          <!-- REDES -->
          <div class="bg-[#1A1A1A] border border-[#2A2A2A] rounded-2xl p-8">
            <h3 class="text-white font-semibold mb-6">Síguenos</h3>
            <div class="flex gap-4">
              <a href="https://x.com/" class="w-12 h-12 bg-[#00FF66]/10 rounded-xl flex items-center justify-center hover:bg-[#00FF66]/20 transition" target="_blank" rel="noreferrer" aria-label="X">
                <Icon name="lucide:twitter" class="w-5 h-5 text-[#00FF66]" />
              </a>
              <a href="https://github.com/" class="w-12 h-12 bg-[#00FF66]/10 rounded-xl flex items-center justify-center hover:bg-[#00FF66]/20 transition" target="_blank" rel="noreferrer" aria-label="GitHub">
                <Icon name="lucide:github" class="w-5 h-5 text-[#00FF66]" />
              </a>
              <a href="https://www.youtube.com/" class="w-12 h-12 bg-[#00FF66]/10 rounded-xl flex items-center justify-center hover:bg-[#00FF66]/20 transition" target="_blank" rel="noreferrer" aria-label="YouTube">
                <Icon name="lucide:youtube" class="w-5 h-5 text-[#00FF66]" />
              </a>
              <a href="https://www.linkedin.com/" class="w-12 h-12 bg-[#00FF66]/10 rounded-xl flex items-center justify-center hover:bg-[#00FF66]/20 transition" target="_blank" rel="noreferrer" aria-label="LinkedIn">
                <Icon name="lucide:linkedin" class="w-5 h-5 text-[#00FF66]" />
              </a>
            </div>
          </div>

          <!-- FAQ rápido -->
          <div class="bg-[#1A1A1A] border border-[#2A2A2A] rounded-2xl p-8">
            <h3 class="text-white font-semibold mb-4">Preguntas rápidas</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <Icon name="lucide:help-circle" class="w-5 h-5 text-[#00FF66] shrink-0 mt-0.5" />
                <div>
                  <p class="text-white text-sm font-medium">¿Cómo solicito un reembolso?</p>
                  <p class="text-[#888] text-xs mt-1">Desde tu perfil → Mis compras → Solicitar reembolso</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Icon name="lucide:help-circle" class="w-5 h-5 text-[#00FF66] shrink-0 mt-0.5" />
                <div>
                  <p class="text-white text-sm font-medium">¿Puedo sugerir un curso?</p>
                  <p class="text-[#888] text-xs mt-1">¡Claro! Usa el formulario y selecciona "Sugerencia"</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Icon name="lucide:help-circle" class="w-5 h-5 text-[#00FF66] shrink-0 mt-0.5" />
                <div>
                  <p class="text-white text-sm font-medium">¿Ofrecéis planes para empresas?</p>
                  <p class="text-[#888] text-xs mt-1">Sí, contáctanos para planes corporativos personalizados</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- FORMULARIO -->
        <div class="bg-[#1A1A1A] border border-[#2A2A2A] rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-white mb-2">Envíanos un mensaje</h2>
          <p class="text-[#888] text-sm mb-8">Rellena el formulario y te contestamos en menos de 24h.</p>
          <ContactForm client:load />
        </div>

      </div>

    </div>
  </section>

  <Footer />
  <BackToTop client:load />
</BaseLayout>
