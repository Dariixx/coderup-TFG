---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import CheckoutPage from "../components/react/CheckoutPage";
---

<BaseLayout title="Checkout" description="Finaliza tu compra en CoderUp conectando el frontend con el backend PHP y la base de datos MySQL.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Checkout</p>
        <h1 class="text-4xl font-bold text-white">Finaliza tu compra</h1>
      </div>
      <CheckoutPage client:load />
    </section>
  </main>
  <Footer />
</BaseLayout>
