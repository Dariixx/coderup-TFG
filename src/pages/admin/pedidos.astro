---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";
import AdminOrdersManager from "../../components/react/admin/AdminOrdersManager";
---

<BaseLayout title="Admin Pedidos" description="Listado administrativo de pedidos para la defensa de la Fase 3 de CoderUp.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Administración</p>
        <h1 class="text-4xl font-bold text-white">Pedidos</h1>
      </div>
      <AdminOrdersManager client:load />
    </section>
  </main>
  <Footer />
</BaseLayout>
