---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import AuthForm from "../components/react/AuthForm";
---

<BaseLayout title="Registro" description="Crea tu cuenta en CoderUp y desbloquea el flujo freemium con cupón de bienvenida WELCOME20.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-xl mx-auto px-4">
      <div class="rounded-3xl border border-[#2A2A2A] bg-[#1A1A1A] p-8 md:p-10">
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Registro</p>
        <h1 class="text-4xl font-bold text-white mb-3">Crea tu cuenta</h1>
        <p class="text-[#888] mb-8">Los nuevos usuarios pueden aplicar WELCOME20 en su primera compra premium.</p>
        <AuthForm client:load mode="register" />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
