---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import AuthForm from "../components/react/AuthForm";
---

<BaseLayout title="Login" description="Accede a tu cuenta de CoderUp para continuar con tus cursos y pedidos.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-xl mx-auto px-4">
      <div class="rounded-3xl border border-[#2A2A2A] bg-[#1A1A1A] p-8 md:p-10">
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Acceso</p>
        <h1 class="text-4xl font-bold text-white mb-3">Inicia sesión</h1>
        <p class="text-[#888] mb-8">Accede con tu cuenta para continuar aprendiendo.</p>
        <AuthForm client:load mode="login" />
        <p class="mt-4 text-center text-sm">
          <a href="/forgot-password" class="text-[#00FF66] hover:underline">He olvidado mi contraseña</a>
        </p>
        <p class="mt-6 text-center text-sm text-[#888]">
          ¿No tienes cuenta?{" "}
          <a href="/register" class="text-[#00FF66] hover:underline">Regístrate gratis</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
