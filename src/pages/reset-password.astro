---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import { ResetPasswordForm } from "../components/react/PasswordRecoveryForms";
---

<BaseLayout title="Nueva contraseña" description="Define una nueva contraseña para tu cuenta de CoderUp.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-xl mx-auto px-4">
      <div class="rounded-3xl border border-[#2A2A2A] bg-[#1A1A1A] p-8 md:p-10">
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Seguridad</p>
        <h1 class="text-4xl font-bold text-white mb-3">Nueva contraseña</h1>
        <p class="text-[#888] mb-8">Crea una contraseña nueva para volver a acceder a tu cuenta.</p>
        <ResetPasswordForm client:load />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
