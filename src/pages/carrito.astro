---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import BackToTop from "../components/react/BackToTop.tsx";
import CartPage from "../components/react/CartPage.tsx";
---

<BaseLayout title="Carrito | CoderUp">
  <Navbar />

  <section class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-10">
        <span class="text-[#00FF66] text-sm font-semibold uppercase tracking-widest">Carrito</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mt-3">Tu carrito</h1>
      </div>

      <CartPage client:load />

    </div>
  </section>

  <Footer />
  <BackToTop client:load />
</BaseLayout>