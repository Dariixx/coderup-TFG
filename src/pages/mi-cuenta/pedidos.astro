---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/layout/Footer.astro";
import Navbar from "../../components/layout/Navbar.astro";
import OrdersPage from "../../components/react/OrdersPage";
---

<BaseLayout title="Pedidos" description="Historial de pedidos de CoderUp: consulta tus compras, subtotal, descuentos y cursos adquiridos.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Pedidos</p>
        <h1 class="text-4xl font-bold text-white">Historial de compras</h1>
      </div>
      <OrdersPage client:load />
    </section>
  </main>
  <Footer />
</BaseLayout>
