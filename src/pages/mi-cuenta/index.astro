---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/layout/Footer.astro";
import Navbar from "../../components/layout/Navbar.astro";
import AccountDashboard from "../../components/react/AccountDashboard";
---

<BaseLayout title="Mi cuenta" description="Dashboard personal de CoderUp con acceso a cursos, pedidos y estado de tu cuenta simulada.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Mi cuenta</p>
        <h1 class="text-4xl font-bold text-white">Tu espacio en CoderUp</h1>
      </div>
      <AccountDashboard client:load />
    </section>
  </main>
  <Footer />
</BaseLayout>
