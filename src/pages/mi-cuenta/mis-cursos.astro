---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/layout/Footer.astro";
import Navbar from "../../components/layout/Navbar.astro";
import MyCoursesPage from "../../components/react/MyCoursesPage";
import { getCourses } from "../../lib/content";

const courses = await getCourses();
---

<BaseLayout title="Mis cursos" description="Consulta tus cursos inscritos o comprados y continúa tu progreso en CoderUp.">
  <Navbar />
  <main class="flex-1 pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-sm uppercase tracking-[0.2em] text-[#00FF66] mb-4">Aprendizaje</p>
        <h1 class="text-4xl font-bold text-white">Mis cursos</h1>
      </div>
      <MyCoursesPage client:load courses={courses} />
    </section>
  </main>
  <Footer />
</BaseLayout>
