---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";
import BackToTop from "../../components/react/BackToTop";
import { getInstructors } from "../../lib/content";

const instructors = await getInstructors();
---

<BaseLayout title="Instructores | CoderUp" description="Conoce a los instructores que crean los cursos de CoderUp.">
  <Navbar />
  <BackToTop client:load />
  <main class="pt-32 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-[#00FF66] text-sm font-semibold uppercase tracking-widest">Instructores</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mt-3 mb-4">Aprende con perfiles senior</h1>
        <p class="text-[#888] text-lg max-w-2xl mx-auto">Profesionales con experiencia real en producto, arquitectura y despliegue.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {instructors.map((instructor) => (
          <a href={`/instructors/${instructor.slug}`} class="rounded-2xl border border-[#2A2A2A] bg-[#1A1A1A] p-6 transition hover:-translate-y-1 hover:border-[#00FF66]/50">
            <div class="mb-5 h-24 w-24 rounded-2xl border border-[#2A2A2A] bg-[#111111] overflow-hidden flex items-center justify-center">
              {instructor.avatarUrl ? (
                <img src={instructor.avatarUrl} alt={instructor.name} class="h-full w-full object-cover" />
              ) : (
                <span class="text-3xl font-bold text-[#00FF66]">{instructor.name.charAt(0)}</span>
              )}
            </div>
            <h2 class="text-xl font-bold text-white mb-1">{instructor.name}</h2>
            <p class="text-[#00FF66] text-sm mb-3">{instructor.specialty ?? instructor.role}</p>
            <p class="text-[#888] text-sm line-clamp-3 mb-5">{instructor.bio}</p>
            <div class="flex items-center justify-between text-xs text-[#888]">
              <span class="flex items-center gap-1"><Icon name="lucide:star" class="w-3 h-3 text-[#00FF66]" /> {instructor.rating}</span>
              <span>{instructor.totalStudents} estudiantes</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

